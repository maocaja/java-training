# =============================================================
# Archivo de ejemplo: copialo a .env y completa valores reales.
# .env esta en .gitignore — NUNCA se commitea con secretos reales.
# =============================================================

# --- JWT ---
# Secret para firmar tokens JWT (HS256).
# En base64, minimo 256 bits (32 bytes decodificados).
# Genera uno nuevo con: openssl rand -base64 32
JWT_SECRET=CHANGE_ME_TO_A_RANDOM_BASE64_KEY_OF_AT_LEAST_32_BYTES=
JWT_EXPIRATION_MS=3600000

# --- Database (solo necesario cuando usas docker-compose con PostgreSQL) ---
POSTGRES_DB=propertydb
POSTGRES_USER=dbadmin
POSTGRES_PASSWORD=CHANGE_ME

# --- Service URLs ---
# Default apunta a containers de docker-compose.
# En dev local (sin Docker) se resuelve a localhost via el yml.
PRICING_SERVICE_URL=http://pricing-api:8082
PROPERTY_SERVICE_URL=http://property-api:8081
